# mcp-sonos configuration — all optional. Copy to .env and edit as needed,
# or set these in your MCP client's `env` block.
#
# See README.md "Configuration" section for full guidance on when to set each.

# --- Speaker discovery ------------------------------------------------------

# Comma-separated speaker IPs. RECOMMENDED for deterministic startup and
# environments where SSDP multicast is unreliable (WSL2 default NAT,
# Docker bridges, isolated guest VLANs, mesh WiFi with broken IGMP).
# Find IPs in your router's client list or the Sonos app.
# SONOS_IPS=192.168.1.10,192.168.1.11,192.168.1.12

# --- Audio host -------------------------------------------------------------

# LAN IP that the audio HTTP server advertises to speakers. Auto-detected
# by default. Override when the host has multiple interfaces (Docker, VPN,
# multi-NIC) and auto-detection picks the wrong one. Must be an IP that
# every Sonos speaker can reach.
# HOST_IP=192.168.1.50

# Pin the audio server to a specific port. Default: first free TCP port
# in 8000-8999. Useful when your firewall allows a single port instead
# of the range.
# AUDIO_PORT=8765

# Directory the `play_file` tool is allowed to stage from. Capability
# scoping for a misaligned agent: without this set, `play_file` is
# disabled and any call returns an error. Paths are resolved (symlinks
# followed) before the containment check, so a symlink under
# AUDIO_MEDIA_ROOT pointing outside will be rejected. Extensions are
# also restricted to mp3/wav/flac/m4a/ogg (case-insensitive). Note:
# this does NOT secure the audio HTTP host itself — anything already
# inside its serve root (TTS WAVs, previously-staged files) remains
# readable by anyone on the LAN who knows the filename.
# AUDIO_MEDIA_ROOT=~/Music/sonos-stage

# --- Piper TTS --------------------------------------------------------------

# Voice name from https://huggingface.co/rhasspy/piper-voices
# Format: <lang>-<speaker>-<quality>. "medium" voices are ~60 MB.
# Examples:
#   en_US-lessac-medium   (default — neutral US female)
#   en_US-amy-medium      (bright US female)
#   en_GB-alan-medium     (British male)
#   es_ES-mls_10246-medium (Spanish)
#   fr_FR-siwis-medium    (French)
#   de_DE-thorsten-medium (German)
# PIPER_VOICE=en_US-lessac-medium

# Where Piper voice models are cached on disk. Set this if you want the
# voice models to persist across container restarts on a mounted volume,
# or just to keep the cache outside the user home dir.
# PIPER_DATA_DIR=/var/cache/mcp-sonos/voices
